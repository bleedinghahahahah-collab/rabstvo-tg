# Get this from @BotFather in Telegram after /newbot
BOT_TOKEN=123456:AAABBBCCCDDDEEEFFF

# Public HTTPS URL where this app is hosted (Telegram Mini Apps require HTTPS).
# For local testing use ngrok/cloudflared and put the tunnel URL here.
WEBAPP_URL=https://your-domain-or-tunnel.example.com

PORT=3000

# false = long polling (fine for local dev)
# true  = webhook mode (recommended in production, needs WEBAPP_URL to be reachable)
USE_WEBHOOK=false
